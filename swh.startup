ip link set eth0 address 00:00:00:00:08:00
ip link set eth1 address 00:00:00:00:08:01
ip link set eth2 address 00:00:00:00:08:02
ip link set eth3 address 00:00:00:00:08:03

p4c /shared/sff.p4 -o /
simple_switch -i 1@eth0 -i 2@eth1 -i 3@eth2 -i 4@eth3 /sff.json &

while [[ $(pgrep simple_switch) -eq 0 ]]; do sleep 1; done
until simple_switch_CLI <<< "help"; do sleep 1; done

simple_switch_CLI <<< $(cat commands.txt)